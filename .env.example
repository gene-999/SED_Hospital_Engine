# Copy this file to .env and fill in values

# MongoDB connection
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=bedready

# JWT — use a long random string in production
SECRET_KEY=change-me-in-production

# Anthropic API key (optional — enables LLM-powered search)
ANTHROPIC_API_KEY=

# Reservation expiry window in minutes (default 40)
RESERVATION_EXPIRY_MINUTES=40
